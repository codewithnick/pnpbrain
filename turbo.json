{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "build:zip": {
      "dependsOn": ["@pnpbrain/widget#build:embed"],
      "outputs": ["dist/*.zip", "assets/pnpbrain-widget.js"],
      "cache": false
    },
    "build:embed": {
      "dependsOn": ["^build"],
      "outputs": ["dist/pnpbrain-widget.js"],
      "inputs": ["embed.tsx", "components/**", "scripts/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
