{
  "name": "crawl-worker",
  "version": "0.0.1",
  "private": true,
  "description": "GCFIS Crawl Worker — Redis queue consumer for crawl jobs",
  "main": "dist/src/worker.js",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/src/worker.js",
    "lint": "echo 'Skipping ESLint for crawl worker'",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@gcfis/agent": "workspace:*",
    "@gcfis/db": "workspace:*",
    "bullmq": "^5.58.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3"
  }
}
