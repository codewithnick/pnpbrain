# ─── Environment Variables for PNpbrain ───────────────────────────────────────
# Copy this file to .env.local in each app or package that needs it.
# Never commit real secrets to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Drizzle + Supabase Postgres) ───────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── Local LLM (Ollama) ───────────────────────────────────────────────────────
# Run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Cloud LLM (optional — comment out for local-only dev) ────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# HUGGINGFACE_API_KEY=hf_...
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_X_TITLE=PNpbrain
# LLM_PROVIDER=ollama   # ollama | openai | anthropic | gemini | deepseek | huggingface | openrouter

# ─── Firecrawl ────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-your-api-key

# ─── Crawl Worker (internal crawler controls) ───────────────────────────────
# Max pages to ingest per seed URL queued for crawl
CRAWL_MAX_PAGES_PER_SEED=10
# HTTP fetch timeout per request in milliseconds
CRAWL_REQUEST_TIMEOUT_MS=15000
# Optional CSV denylist (exact domains or wildcard like *.example.com)
# CRAWL_BLOCKED_DOMAINS=private.example.com
# Expected vector dimensions for `knowledge_chunks.embedding` (default matches schema)
KNOWLEDGE_EMBEDDING_DIMENSIONS=1536

# ─── Redis Queue (BullMQ) ─────────────────────────────────────────────────────
# Preferred (direct Redis protocol)
REDIS_URL=redis://localhost:6379
# BullMQ requires Redis `maxmemory-policy noeviction` for reliable queue semantics.
# Example local command: `redis-cli CONFIG SET maxmemory-policy noeviction`
# Upstash fallback (auto-converted to rediss:// for queue + worker)
# UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ─── AWS S3 (knowledge base uploads) ─────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_KNOWLEDGE_BUCKET=your-knowledge-bucket

# ─── Backend API (called by widget + admin) ───────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_PUBLIC_URL=http://localhost:3001
BACKEND_API_SECRET=change-me-super-secret-32-chars
OAUTH_STATE_SECRET=change-me-oauth-state-secret
# Optional: when set, dashboard/billing shows used vs remaining API credits.
# If omitted, credits are treated as unlimited.
# BILLING_INCLUDED_API_CREDITS=10000

# ─── Billing Providers (optional) ────────────────────────────────────────────
BILLING_SUPPORT_EMAIL=support@pnpbrain.com
# Stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_LITE=price_...
# STRIPE_PRICE_ID_BASIC=price_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_CREDIT_UNIT_AMOUNT_CENTS=100
# STRIPE_CURRENCY=usd
# Razorpay
# RAZORPAY_KEY_ID=rzp_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# RAZORPAY_CREDIT_UNIT_AMOUNT_PAISE=100
# RAZORPAY_CURRENCY=INR
# Wise transfer instructions
# WISE_RECIPIENT_NAME=PNPBRAIN Billing
# WISE_EMAIL=billing@pnpbrain.com
# WISE_CURRENCY=USD
# WISE_BANK_NAME=Wise
# WISE_IBAN=...
# WISE_SWIFT_BIC=...
# WISE_ACCOUNT_NUMBER=...
# WISE_ROUTING_NUMBER=...

# ─── Meeting Integrations (OAuth) ─────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
ZOOM_OAUTH_CLIENT_ID=your-zoom-oauth-client-id
ZOOM_OAUTH_CLIENT_SECRET=your-zoom-oauth-client-secret

# ─── Admin App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ─── Widget ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WIDGET_URL=http://localhost:3003

# ─── Marketing ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000

# ─── WordPress Plugin ─────────────────────────────────────────────────────────
WP_PLUGIN_BACKEND_URL=https://your-backend-domain.com
