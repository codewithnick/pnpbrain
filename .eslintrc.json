{
  "root": true,
  "ignorePatterns": [
    "**/.next/**",
    "**/dist/**",
    "**/node_modules/**",
    "packages/db/drizzle/**"
  ],
  "overrides": [
    {
      "files": [
        "apps/admin/**/*.{js,jsx,ts,tsx}",
        "apps/marketing/**/*.{js,jsx,ts,tsx}",
        "apps/widget/**/*.{js,jsx,ts,tsx}"
      ],
      "extends": ["next/core-web-vitals"]
    },
    {
      "files": [
        "apps/backend/**/*.ts",
        "apps/crawl-worker/**/*.ts",
        "packages/**/*.ts"
      ],
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
      "env": {
        "node": true,
        "es2022": true
      },
      "rules": {
        "@typescript-eslint/no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ]
      }
    }
  ]
}
