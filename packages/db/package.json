{
  "name": "@pnpbrain/db",
  "version": "0.0.1",
  "private": true,
  "description": "Drizzle ORM schemas, Supabase client, migrations — shared only with backend",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:ensure-extensions": "node ./scripts/ensure-db-extensions.mjs",
    "db:migrate": "pnpm run db:ensure-extensions && drizzle-kit migrate",
    "db:push": "pnpm run db:ensure-extensions && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:status": "node ./scripts/db-status.mjs ../../.env.local",
    "db:status:prod": "node ./scripts/db-status.mjs ../../.env.prod",
    "db:compare": "node ./scripts/compare-db-sync.mjs ../../.env.local ../../.env.prod",
    "db:compare:strict": "node ./scripts/compare-db-sync.mjs --strict ../../.env.local ../../.env.prod",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pnpbrain/types": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
