{
  "name": "@pnpbrain/tools",
  "version": "0.0.1",
  "private": true,
  "description": "LangGraph tool definitions — Firecrawl, calculator, datetime, etc.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pnpbrain/db": "workspace:*",
    "@pnpbrain/types": "workspace:*",
    "@langchain/core": "^0.3.37",
    "@mendable/firecrawl-js": "^1.16.0",
    "axios": "^1.11.0",
    "langchain": "^0.3.19",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
