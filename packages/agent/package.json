{
  "name": "@pnpbrain/agent",
  "version": "0.0.1",
  "private": true,
  "description": "LangGraph.js agent graph, prompts, memory, RAG — shared only with backend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./graph": {
      "types": "./src/graph.ts",
      "import": "./src/graph.ts",
      "require": "./dist/graph.js",
      "default": "./dist/graph.js"
    },
    "./llm": {
      "types": "./src/llm.ts",
      "import": "./src/llm.ts",
      "require": "./dist/llm.js",
      "default": "./dist/llm.js"
    },
    "./memory": {
      "types": "./src/memory.ts",
      "import": "./src/memory.ts",
      "require": "./dist/memory.js",
      "default": "./dist/memory.js"
    },
    "./rag": {
      "types": "./src/rag.ts",
      "import": "./src/rag.ts",
      "require": "./dist/rag.js",
      "default": "./dist/rag.js"
    },
    "./prompts": {
      "types": "./src/prompts.ts",
      "import": "./src/prompts.ts",
      "require": "./dist/prompts.js",
      "default": "./dist/prompts.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pnpbrain/db": "workspace:*",
    "@pnpbrain/tools": "workspace:*",
    "@pnpbrain/types": "workspace:*",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.37",
    "@langchain/google-genai": "^0.2.18",
    "@langchain/langgraph": "^0.2.40",
    "@langchain/ollama": "^0.1.5",
    "@langchain/openai": "^0.6.17",
    "drizzle-orm": "^0.38.3",
    "langchain": "^0.3.19",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
